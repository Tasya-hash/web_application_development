<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sass.js/0.9.12/sass.sync.min.js"></script>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg-color: #008080; 
            --text-primary: #333;
            --text-light: #f5f5f5;
            --accent-green: #4CAF50;
            --accent-red: #8B0000;
            --item-bg: #e0e0e0;
            --item-bg-hover: #d0d0d0;
            --done-bg: #8c8c8c;
            --date-color: #a9a9a9;
            --border-color: #666;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: var(--bg-color);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .app {
            width: 100%;
            max-width: 600px;
            background-color: white;
            border-radius: 8px;
            
            overflow: hidden;
            display: flex;
            flex-direction: column;
            max-height: 90vh;
        }

        .header {
            background-color: var(--bg-color);
            padding: 20px;
            text-align: center;
        }

        .header h1 {
            font-family: 'Lobster', cursive;
            font-size: 42px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            margin: 0;
        }

        .header h1::before {
            content: '';
            font-size: 48px;
            filter: drop-shadow(2px 2px 4px rgba(0,0,0,0.3));
        }

        .panel {
            display: flex;
            padding: 20px;
            gap: 10px;
            background-color: white;
            border-bottom: 1px solid #ddd;
        }

        .panel input {
            flex: 1;
            padding: 12px;
            font-size: 16px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-family: 'Roboto', sans-serif;
        }

        .panel input::placeholder {
            color: #999;
        }

        .panel button {
            padding: 12px 20px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 700;
            font-size: 14px;
            transition: all 0.3s ease;
            white-space: nowrap;
        }

        .panel .create {
            background-color: #e0e0e0;
            color: var(--text-primary);
        }

        .panel .create:hover {
            background-color: #d0d0d0;
            transform: translateY(-2px);
        }

        .panel .clear {
            background-color: var(--accent-red);
            color: white;
        }

        .panel .clear:hover {
            background-color: #a00000;
            transform: translateY(-2px);
        }

        .list-container {
            flex: 1;
            overflow-y: auto;
            background-color: #f8f8f8;
            padding: 10px;
            min-height: 200px;
        }

        .todo-list {
            list-style: none;
        }

        .todo-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--item-bg);
            margin-bottom: 2px;
            padding: 12px 15px;
            transition: background-color 0.3s;
        }

        .todo-item:hover {
            background-color: var(--item-bg-hover);
        }

        .todo-item.completed {
            background-color: var(--done-bg);
            color: white;
        }

        .todo-item.completed:hover {
            background-color: #7a7a7a;
        }

        .todo-content {
            display: flex;
            align-items: center;
            gap: 12px;
            flex: 1;
            min-width: 0;
        }

        .todo-content input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .text-wrapper {
            display: flex;
            flex-direction: column;
            min-width: 0;
            flex: 1;
        }

        .todo-text {
            font-size: 16px;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .todo-item.completed .todo-text {
            text-decoration: line-through;
        }

        .todo-date {
            font-size: 12px;
            color: var(--date-color);
            margin-top: 2px;
        }

        .todo-item.completed .todo-date {
            color: #ccc;
        }

        .remove-btn {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: #ff4444;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            transition: all 0.3s;
            margin-left: 10px;
            flex-shrink: 0;
        }

        .remove-btn:hover {
            background-color: #ff4444;
            color: white;
            transform: rotate(90deg);
        }

        .empty-message {
            text-align: center;
            padding: 50px 20px;
            color: #666;
            font-size: 18px;
            font-style: italic;
            display: none;
        }

        .todo-list:empty + .empty-message {
            display: block;
        }

        .footer {
            background-color: var(--bg-color);
            color: white;
            text-align: center;
            padding: 15px;
            font-size: 14px;
        }

        @media (max-width: 500px) {
            .panel {
                flex-wrap: wrap;
            }
            
            .panel input {
                flex: 1 1 100%;
                order: 1;
            }
            
            .panel .create {
                flex: 1;
                order: 2;
            }
            
            .panel .clear {
                flex: 1;
                order: 3;
            }

            .header h1 {
                font-size: 32px;
            }
            
            .header h1::before {
                font-size: 36px;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <header class="header">
            <h1>Список дел</h1>
        </header>

        <div class="panel">
            <input type="text" placeholder="Новый элемент списка">
            <button type="submit" class="create">Создать</button>
            <button type="reset" class="clear">Очистить всё</button>
        </div>

        <div class="list-container">
            <ul class="todo-list">
                <li class="todo-item">
                    <div class="todo-content">
                        <input type="checkbox" class="todo-checkbox">
                        <div class="text-wrapper">
                            <span class="todo-text">Почесать кошку</span>
                            <span class="todo-date">от 24.08.2023</span>
                        </div>
                    </div>
                    <button class="remove-btn">✖</button>
                </li>
                
                <li class="todo-item">
                    <div class="todo-content">
                        <input type="checkbox" class="todo-checkbox">
                        <div class="text-wrapper">
                            <span class="todo-text">Полить картошку</span>
                            <span class="todo-date">от 04.05.2022</span>
                        </div>
                    </div>
                    <button class="remove-btn">✖</button>
                </li>
                
                <li class="todo-item">
                    <div class="todo-content">
                        <input type="checkbox" class="todo-checkbox">
                        <div class="text-wrapper">
                            <span class="todo-text">Сложить в лукошко</span>
                            <span class="todo-date">от 19.05.2022</span>
                        </div>
                    </div>
                    <button class="remove-btn">✖</button>
                </li>
            </ul>
            <div class="empty-message">Не найдено ни одного дела</div>
        </div>

        <footer class="footer">
            <hr>
            <div>Copyright ©</div>
        </footer>
    </div>

    <script>
        document.querySelectorAll('.todo-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const todoItem = this.closest('.todo-item');
                if (this.checked) {
                    todoItem.classList.add('completed');
                } else {
                    todoItem.classList.remove('completed');
                }
            });
        });
    </script>
</body>
</html>
